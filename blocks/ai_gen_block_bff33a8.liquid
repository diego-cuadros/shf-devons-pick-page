{% doc %}
  @prompt
    Layout & Structure
    Four testimonial cards are arranged in a grid (two rows, two columns).
    
    Each card contains:
    
    Profile photo (circular image).
    
    Name (bold).
    
    Role/Title (lighter text under name).
    
    Quote (personal feedback in quotation marks).
    
    Purpose
    To build trust and credibility by showcasing real people’s experiences.
    
    Highlights different perspectives — tech, investment, wellness, and entrepreneurship — to appeal to a broad audience.
    
    Content Summary
    Sarah Chen – Tech Founder
    Praises the unique blend of business insight and wellness practices.
    
    Marcus Rodriguez – Investment Partner
    Appreciates the investment/networking opportunities and decision-making clarity.
    
    Emily Thompson – Wellness Coach
    Values the focus on both physical and mental wellbeing, calling facilities world-class.
    
    David Kim – Serial Entrepreneur
    Highlights weekly calls with industry leaders and business growth connections.
    
    Design Notes
    Minimal, clean white background.
    
    Rounded corners for each card give a friendly, modern look.
    
    Consistent text alignment for readability.
    
    Mix of professional and lifestyle roles for relatability.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonials-grid-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-testimonials-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-testimonials-heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.heading_margin }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin-top: 0;
  }

  .ai-testimonials-grid-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-testimonial-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-testimonial-photo-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.photo_size }}px;
    height: {{ block.settings.photo_size }}px;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: 16px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-photo-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-photo-wrapper-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    color: #ccc;
  }

  .ai-testimonial-name-{{ ai_gen_id }} {
    font-weight: 600;
    font-size: {{ block.settings.name_size }}px;
    color: {{ block.settings.name_color }};
    margin: 0 0 4px;
  }

  .ai-testimonial-role-{{ ai_gen_id }} {
    font-size: {{ block.settings.role_size }}px;
    color: {{ block.settings.role_color }};
    margin: 0 0 16px;
    opacity: 0.8;
  }

  .ai-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    color: {{ block.settings.quote_color }};
    line-height: 1.6;
    margin: 0;
    font-style: italic;
  }

  .ai-testimonial-quote-{{ ai_gen_id }}::before {
    content: """;
    font-size: 1.2em;
    color: {{ block.settings.quote_marks_color }};
  }

  .ai-testimonial-quote-{{ ai_gen_id }}::after {
    content: """;
    font-size: 1.2em;
    color: {{ block.settings.quote_marks_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-testimonials-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_spacing | times: 0.75 }}px;
    }

    .ai-testimonial-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.8 }}px;
    }

    .ai-testimonials-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-testimonials-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}><div class="ai-testimonials-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-testimonials-grid-wrapper-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign name_key = 'testimonial_' | append: i | append: '_name'
          assign role_key = 'testimonial_' | append: i | append: '_role'
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign photo_key = 'testimonial_' | append: i | append: '_photo'

          assign name = block.settings[name_key]
          assign role = block.settings[role_key]
          assign quote = block.settings[quote_key]
          assign photo = block.settings[photo_key]
        %}

        <div class="ai-testimonial-card-{{ ai_gen_id }}">
          <div class="ai-testimonial-photo-wrapper-{{ ai_gen_id }}">
            {% if photo %}
              <img
                src="{{ photo | image_url: width: 200 }}"
                alt="{{ name | escape }}"
                class="ai-testimonial-photo-{{ ai_gen_id }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            {% endif %}
          </div>

          {% if name != blank %}
            <h3 class="ai-testimonial-name-{{ ai_gen_id }}">{{ name }}</h3>
          {% endif %}

          {% if role != blank %}
            <p class="ai-testimonial-role-{{ ai_gen_id }}">{{ role }}</p>
          {% endif %}

          {% if quote != blank %}
            <p class="ai-testimonial-quote-{{ ai_gen_id }}">{{ quote }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

