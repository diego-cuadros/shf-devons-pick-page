{% comment %} Features / Differentiators — compact, schema-safe {% endcomment %}
<section
  id="features-{{ section.id }}"
  class="features {{ section.settings.section_classes }}"
  style="
    --bg: {{ section.settings.bg_color }};
    --card-bg: {{ section.settings.card_bg }};
    --card-br: {{ section.settings.card_border_color }};
    --radius: {{ section.settings.card_radius }}px;
    --shadow: {% if section.settings.card_shadow %}0 6px 18px rgba(0,0,0,.06){% else %}none{% endif %};
    --icon-size: {{ section.settings.icon_size }}px;
    --icon-bg: {{ section.settings.icon_bg }};
    --gap: {{ section.settings.gap }}px;
  "
>
  <div class="{{ section.settings.custom_class }} features__inner {{ section.settings.container_classes }}">
    {% if section.settings.heading != blank %}
      <h2 class="features__heading {{ section.settings.heading_classes }}">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="features__sub {{ section.settings.subheading_classes }}">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="features__grid {{ section.settings.grid_classes }}"
         style="--cols-tab: {{ section.settings.cols_tablet }}; --cols-desk: {{ section.settings.cols_desktop }};">
      {% for block in section.blocks %}
        {% assign b = block.settings %}
        <article class="features__card {{ section.settings.card_classes }}" {{ block.shopify_attributes }}>
          <div class="features__iconwrap {{ section.settings.icon_wrap_classes }}"
               style="--icon-bg-local:{% if b.icon_bg != blank %}{{ b.icon_bg }}{% else %}var(--icon-bg){% endif %}">
            <div class="features__icon">
              {% if b.icon_image != blank %}
                <img
                  src="{{ b.icon_image | img_url: 'master' }}"
                  alt=""
                  width="64" height="64"
                  class="features__iconimg {{ section.settings.icon_img_classes }}"
                  loading="lazy">
              {% elsif b.icon_emoji != blank %}
                <span class="features__emoji {{ section.settings.icon_emoji_classes }}">{{ b.icon_emoji }}</span>
              {% else %}
                <span class="features__emoji {{ section.settings.icon_emoji_classes }}">⭐</span>
              {% endif %}
            </div>
          </div>

          {% if b.title != blank %}<h3 class="features__title {{ section.settings.title_classes }}">{{ b.title }}</h3>{% endif %}
          {% if b.text != blank %}<p class="features__text {{ section.settings.text_classes }}">{{ b.text }}</p>{% endif %}
          {% if b.link_label != blank and b.link_url != blank %}
            <a href="{{ b.link_url }}" class="features__link {{ section.settings.link_classes }}">{{ b.link_label }}</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  </div>

  <style>
    #features-{{ section.id }}{ background: var(--bg); padding: {{ section.settings.pad_y_m }}px 0; }
    @media (min-width: 768px){ #features-{{ section.id }}{ padding: {{ section.settings.pad_y_d }}px 0; } }

    #features-{{ section.id }} .features__inner{ max-width: {{ section.settings.max_w }}px; margin: 0 auto; padding: 0 20px; }
    #features-{{ section.id }} .features__heading{ margin: 0 0 8px; line-height: 1.2; text-align: center; }
    #features-{{ section.id }} .features__sub{ margin: 0 auto 28px; opacity:.85; max-width: 860px; text-align: center; }

    #features-{{ section.id }} .features__grid{
      display: grid; gap: var(--gap);
      grid-template-columns: repeat(1, minmax(0,1fr)); /* mobile */
    }
    @media (min-width: 768px){
      #features-{{ section.id }} .features__grid{ grid-template-columns: repeat(var(--cols-tab), minmax(0,1fr)); }
    }
    @media (min-width: 1024px){
      #features-{{ section.id }} .features__grid{ grid-template-columns: repeat(var(--cols-desk), minmax(0,1fr)); }
    }

    #features-{{ section.id }} .features__card{
      background: var(--card-bg); border: 1px solid var(--card-br);
      border-radius: var(--radius); box-shadow: var(--shadow); padding: 24px;
    }
    #features-{{ section.id }} .features__iconwrap{
      border-radius: 999px; background: var(--icon-bg-local);
      display: inline-flex; align-items: center; justify-content: center; margin-bottom: 14px;
    }
    #features-{{ section.id }} .features__icon{ width: var(--icon-size); height: var(--icon-size); display:grid; place-items:center; }
    #features-{{ section.id }} .features__iconimg{ width: 100%; height: 100%; object-fit: contain; }
    #features-{{ section.id }} .features__emoji{ font-size: calc(var(--icon-size)*0.75); line-height:1; }
    #features-{{ section.id }} .features__title{ margin: 6px 0 8px; font-weight: 700; }
    #features-{{ section.id }} .features__text{ margin: 0; opacity: .9; }
    #features-{{ section.id }} .features__link{ display:inline-block; margin-top:8px; text-decoration: underline; }
  </style>
</section>

{% schema %}
{
  "name": "Features",
  "settings": [
    { "type": "text", "id": "custom_class", "label": "Add Custom Class"},
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Makes Us Different" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "We’ve created a unique ecosystem where business growth, personal wellness, and meaningful connections flourish together." },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "cols_tablet", "min": 1, "max": 3, "step": 1, "default": 2, "label": "Columns (tablet)" },
    { "type": "range", "id": "cols_desktop", "min": 2, "max": 4, "step": 1, "default": 3, "label": "Columns (desktop)" },
    { "type": "range", "id": "gap", "min": 8, "max": 40, "step": 2, "default": 20, "label": "Grid gap (px)" },
    { "type": "range", "id": "max_w", "min": 800, "max": 1600, "step": 20, "default": 1200, "label": "Container max width (px)" },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "pad_y_m", "min": 20, "max": 120, "step": 4, "default": 48, "label": "Vertical padding (mobile)" },
    { "type": "range", "id": "pad_y_d", "min": 40, "max": 160, "step": 4, "default": 80, "label": "Vertical padding (desktop)" },

    { "type": "header", "content": "Colors & Style" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#FFF6E8" },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#FFFFFF" },
    { "type": "color", "id": "card_border_color", "label": "Card border", "default": "#E6E6E6" },
    { "type": "range", "id": "card_radius", "min": 0, "max": 28, "step": 2, "default": 16, "label": "Card border radius" },
    { "type": "checkbox", "id": "card_shadow", "default": true, "label": "Soft shadow on cards" },

    { "type": "color", "id": "icon_bg", "label": "Default icon background", "default": "#DFF5E5" },
    { "type": "range", "id": "icon_size", "min": 32, "max": 80, "step": 4, "default": 48, "label": "Icon size (px)" },

    { "type": "header", "content": "Custom classes (optional)" },
    { "type": "text", "id": "section_classes", "label": "Section wrapper classes" },
    { "type": "text", "id": "container_classes", "label": "Container classes" },
    { "type": "text", "id": "grid_classes", "label": "Grid classes" },
    { "type": "text", "id": "card_classes", "label": "Card classes" },
    { "type": "text", "id": "icon_wrap_classes", "label": "Icon wrap classes" },
    { "type": "text", "id": "icon_img_classes", "label": "Icon image classes" },
    { "type": "text", "id": "icon_emoji_classes", "label": "Icon emoji classes" },
    { "type": "text", "id": "heading_classes", "label": "Heading classes" },
    { "type": "text", "id": "subheading_classes", "label": "Subheading classes" },
    { "type": "text", "id": "title_classes", "label": "Card title classes" },
    { "type": "text", "id": "text_classes", "label": "Card text classes" },
    { "type": "text", "id": "link_classes", "label": "Link classes" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Weekly Industry Leader Calls" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Live, members-only sessions with founders and experts." },
        { "type": "image_picker", "id": "icon_image", "label": "Icon image (optional)" },
        { "type": "text", "id": "icon_emoji", "label": "Emoji (fallback if no image)", "default": "📞" },
        { "type": "color", "id": "icon_bg", "label": "Icon background (optional)" },
        { "type": "text", "id": "link_label", "label": "Link label (optional)" },
        { "type": "url", "id": "link_url", "label": "Link URL (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features",
      "blocks": [
        { "type": "feature", "settings": { "title": "Weekly Industry Leader Calls", "text": "Live, members-only sessions with founders and experts.", "icon_emoji": "📞" } },
        { "type": "feature", "settings": { "title": "Private Group Chats", "text": "Direct access to high-level founders, investors, and operators.", "icon_emoji": "💬" } },
        { "type": "feature", "settings": { "title": "Exclusive Investment Access", "text": "Early access to real estate and business deals.", "icon_emoji": "💲" } },
        { "type": "feature", "settings": { "title": "20 Acres of Amenities", "text": "Cold plunge, gym, red light therapy, sauna, trails, and more.", "icon_emoji": "🌲" } },
        { "type": "feature", "settings": { "title": "Lifestyle Meets Growth", "text": "Where business success and wellbeing go hand in hand.", "icon_emoji": "💚" } },
        { "type": "feature", "settings": { "title": "Curated Community", "text": "Connect with like-minded entrepreneurs and wellness enthusiasts.", "icon_emoji": "👥" } }
      ]
    }
  ]
}
{% endschema %}
