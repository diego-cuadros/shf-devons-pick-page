    "17558002013b1668ea": {
      "type": "_blocks",
      "blocks": {
        "ai_gen_block_bff33a8_zhAdWD": {
          "type": "ai_gen_block_bff33a8",
          "settings": {
            "heading": "",
            "testimonial_1_name": "Evan R.",
            "testimonial_1_role": "⭐ ⭐ ⭐ ⭐ ⭐",
            "testimonial_1_quote": "My happy place. From the plentiful gardens of amazing produce to the state-of-the-art facilities, this place is truly one of a kind. I have met the most amazing people who have pushed me to do more. I owe a lot to this place. Oh…. And my fiancé and I are getting married here!",
            "testimonial_1_photo": "shopify://shop_images/Evan_R.png",
            "testimonial_2_name": "Ashley L.",
            "testimonial_2_role": "⭐ ⭐ ⭐ ⭐ ⭐",
            "testimonial_2_quote": "It’s hard to put into words just how much I appreciate this place. The sense of community, the warmth of the animals, and the thoughtful amenities make every day special. There’s always a positive atmosphere and so many meaningful memories created here. I’m truly grateful to be a part of a place that brings so much joy and peace and most importantly... community🫶",
            "testimonial_2_photo": "shopify://shop_images/Ashley_L.png",
            "testimonial_3_name": "Max K.",
            "testimonial_3_role": "⭐ ⭐ ⭐ ⭐ ⭐",
            "testimonial_3_quote": "Sweet Honey Farm is the best! A perfect blend of a work space gym and wellness. I can take a break from writing an email in the farmstand with fresh coffee before getting a workout in with like minded people, hit the sauna that’s always hot, cold plunge and eat a fresh cooked farm sourced meal by a rockstar chef!",
            "testimonial_3_photo": "shopify://shop_images/Max_Kats.png",
            "testimonial_4_name": "Jake D.",
            "testimonial_4_role": "⭐ ⭐ ⭐ ⭐ ⭐",
            "testimonial_4_quote": "The truest definition of Good old-fashioned FUN! Sweet Honey Farm is such a unique place; from the amazing fitness facilities, cold plunges, saunas, to the wildlife with horses, cows,  chickens, to the organic gardens and fresh produce, to the amazing coffee stand and kitchen serving the best light bites!!! We ALWAYS have a great time at Sweet Honey Farm!",
            "testimonial_4_photo": "shopify://shop_images/Jake_D.png",
