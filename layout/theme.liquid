    console.log("in liquide")

function initKlaviyoTracking() {
  let attempts = 0;
  const maxAttempts = 24; // Check for 2 minutes (24 attempts × 5 seconds = 120 seconds)
  
  function checkForKlaviyo() {
    const klaviyoForm = document.querySelector('[data-testid="klaviyo-form-SWzbbm"]');
    
    if (klaviyoForm) {
      console.log('Klaviyo form found after', attempts + 1, 'attempts');
      
      // Track button clicks
      const button = klaviyoForm.querySelectorAll('button')[1];
      if (button) {
        button.addEventListener('click', async function() {
          const email = klaviyoForm.querySelector('input[placeholder="Email"]')?.value;
          
          if (email && email.includes('@') && typeof fbq !== 'undefined') {
            try {
              // Hash the email
              const hashedEmail = await hashEmail(email);
              
              fbq('track', 'Lead', {
                content_name: 'Membership Interest Form',
                em: hashedEmail
              });
              
              console.log('Klaviyo Lead event sent to Meta with hashed email');
            } catch (error) {
              // Fallback without hashed email if hashing fails
              console.log('Email hashing failed, sending without hash');
              fbq('track', 'Lead', {
                content_name: 'Membership Interest Form'
              });
            }
          }
        });
        
        console.log('Klaviyo form tracking initialized successfully');
        return; // Stop checking once we've set up the tracking
      }
    }
    
    attempts++;
    if (attempts < maxAttempts) {
      console.log('Klaviyo form not found, retrying... (attempt', attempts, 'of', maxAttempts + ')');
      setTimeout(checkForKlaviyo, 1200); // Check every 1 seconds
    } else {
      console.log('Klaviyo form not found after 2 minutes, stopping search');
    }
  }
  
  // Start checking immediately
  checkForKlaviyo();
}

// Start the tracking initialization
initKlaviyoTracking();

// Hash email function
async function hashEmail(email) {
  const normalizedEmail = email.toLowerCase().trim();
  const encoder = new TextEncoder();
  const data = encoder.encode(normalizedEmail);
  const hashBuffer = await crypto.subtle.digest('SHA-256', data);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
}
