<script>
function getVariantFromURL() {
    const urlParams = new URLSearchParams(window.location.search);
    const variant = urlParams.get('variant');
    console.log("Extracted Variant ID:", variant);
    return variant;
}

function getProductIdFromLoopWidget() {
    if (typeof LOOP_WIDGET === 'undefined') {
        console.log("LOOP_WIDGET is not defined.");
        return null;
    }

    const productIds = Object.keys(LOOP_WIDGET);
    if (productIds.length === 0) {
        console.log("No product ID found in LOOP_WIDGET.");
        return null;
    }

    const pid = productIds[0];
    console.log("Extracted Product ID from LOOP_WIDGET:", pid);
    return pid;
}

function handleVariantChange() {
    const variantId = getVariantFromURL();
    if (!variantId) {
        console.log("No variant ID found in URL.");
        return;
    }

    const pid = getProductIdFromLoopWidget();
    if (!pid) {
        console.log("Failed to get product ID.");
        return;
    }

    const inputElement = document.querySelector('input[name="product-id"]');
    if (inputElement && window?.LoopSubscriptions) {
        setTimeout(() => {
            console.log(
                "Updating LoopSubscriptions with product ID:",
                inputElement.value,
                "and variant ID:",
                variantId
            );
            window.LoopSubscriptions.handleLoopWidgetVariantIdChange(
                Number(inputElement.value),
                Number(variantId)
            );
        }, 0);
    } else {
        console.warn("LoopSubscriptions or product-id input not available.");
    }
}

// Run on page load
document.addEventListener("DOMContentLoaded", handleVariantChange);

// Listen for SPA URL changes (history API manipulation)
(function () {
    let lastUrl = location.href;

    new MutationObserver(() => {
        if (location.href !== lastUrl) {
            lastUrl = location.href;
            console.log("URL changed, re-running variant check.");
            handleVariantChange();
        }
    }).observe(document, { subtree: true, childList: true });

    window.addEventListener('popstate', handleVariantChange);
})();
</script>
<script>
  (function monitorLoopWidget() {
  const targetButtonSelector = "#ProductSubmitButton-template--25047349428517__product-form span[data-add-to-cart-text]";

  const updateButtonText = () => {
    // Make sure LOOP_WIDGET exists and has at least one key
    const loopDataObj = window.LOOP_WIDGET;
    if (!loopDataObj || Object.keys(loopDataObj).length === 0) return;

    // Get the first product ID dynamically
    const productId = Object.keys(loopDataObj)[0];
    const loopData = loopDataObj[productId];

    if (!loopData) return;

    const selectedPlanId = loopData.selectedSellingPlanId;
    const buttonTextElement = document.querySelector(targetButtonSelector);

    if (!buttonTextElement) return;

    const currentText = buttonTextElement.textContent.trim();

    if (selectedPlanId && currentText !== "Add Membership to Cart") {
      buttonTextElement.textContent = "Add Membership to Cart";
    } else if (!selectedPlanId && currentText !== "Add to Cart") {
      buttonTextElement.textContent = "Add to Cart";
    }
  };

  // Monitor every 500ms
  setInterval(updateButtonText, 500);
})();

</script>
